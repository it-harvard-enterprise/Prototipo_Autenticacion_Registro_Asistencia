SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended for /api/auth/* public auth calls.
SUPABASE_ANON_KEY=
BIOMETRIC_PASSPHRASE_PNG=
BIOMETRIC_PASSPHRASE_TEMPLATE=
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_HEALTH_URL=http://localhost:3000

MATCH_THRESHOLD=40
PORT=4000

# --- SMS notifications (Twilio) ---
# Credentials from the Twilio console (https://console.twilio.com).
# Leave blank to disable Twilio calls entirely (the feature falls back
# to dry-run logging if SMS_NOTIFICATIONS_ENABLED is true).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Master kill-switch. When false, no SMS code path runs at all.
SMS_NOTIFICATIONS_ENABLED=false

# When true, every Notify* call logs the would-be SMS to stdout and
# does NOT hit the Twilio API. Useful before upgrading the Twilio
# account out of trial. Set to false only when ready to send real SMS.
SMS_NOTIFICATIONS_DRY_RUN=true

# Per-case toggles. Each one is checked independently AFTER the master
# switch. Defaults below are conservative; flip individually to true
# when ready.
SMS_NOTIFY_PAYMENT=false              # Case 1: payment confirmation
SMS_NOTIFY_ATTENDANCE_PRESENT=false   # Case 2: present (kept off to save cost)
SMS_NOTIFY_ATTENDANCE_ABSENT=false    # Case 3: absent
